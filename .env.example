# Копировать в .env.test (не коммитить!)
DB_USER=pm_agent_test
DB_NAME=pm_agent_test
DB_PASSWORD=changeme

YC_API_KEY=
YC_FOLDER_ID=

# OpenRouter (LLM: pm_agent / meeting_summarizer → google/gemini-3.1-flash-lite)
OPENROUTER_API_KEY=

# Tracker
TRACKER_TOKEN=
TRACKER_ORG_ID=
TRACKER_MCP_URL=https://example.mcpgw.serverless.yandexcloud.net/sse
TRACKER_MCP_TOKEN=
TRACKER_MCP_TIMEOUT=60

# Default team for single-tenant DB persistence (actions/traces/confirms).
# When set together with DATABASE_URL, the orchestrator persists to this team.
DEFAULT_TEAM_ID=00000000-0000-0000-0000-000000000001

ENVIRONMENT=test
LOG_LEVEL=DEBUG
RUNTIME_SKIP_TOOL_CONFIRM=true

# Hourly Telegram digest
DAILY_DIGEST_ENABLED=true
DAILY_DIGEST_CRON_EXPR=0 * * * *
DAILY_DIGEST_TIMEZONE=Europe/Moscow
DAILY_DIGEST_TELEGRAM_CHAT_ID=
DAILY_DIGEST_IN_PROGRESS_STATUSES=In Progress,В работе
DAILY_DIGEST_MAX_ISSUES_PER_SECTION=10

# Deadline reminders (private DMs per-assignee + lead summary)
# Phase 1 (hourly):    DEADLINE_REMINDER_CRON_EXPR=0 * * * *
# Phase 2 (16:00 MSK): DEADLINE_REMINDER_CRON_EXPR=0 13 * * *
DEADLINE_REMINDER_ENABLED=true
DEADLINE_REMINDER_CRON_EXPR=0 * * * *
DEADLINE_REMINDER_TIMEZONE=Europe/Moscow
DEADLINE_REMINDER_SOON_DAYS=3
DEADLINE_REMINDER_MAX_ISSUES_PER_MEMBER=20
DEADLINE_REMINDER_NOTIFY_ASSIGNEES=true
DEADLINE_REMINDER_NOTIFY_LEAD=true
DEADLINE_REMINDER_LEAD_ROLES=lead,admin
DEADLINE_REMINDER_LEAD_LOGIN=nukolaus

# Console GUI
PLATFORM_API_URL=http://platform-api:8000
CONSOLE_ADMIN_EMAIL=admin@example.com
CONSOLE_ADMIN_PASSWORD=admin
CONSOLE_LOGIN_CODE_SECRET=replace-with-a-long-random-secret
CONSOLE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
