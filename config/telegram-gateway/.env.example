# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
TELEGRAM_WEBHOOK_BASE_URL=https://gateway.example.com

# === MAIN BRIDGE ===
MAIN_BRIDGE_URL=https://main-server.internal/internal/telegram/v1
TELEGRAM_BRIDGE_HMAC_KEY_ID=key1
TELEGRAM_BRIDGE_HMAC_KEYS=key1:your_hmac_secret_here
TELEGRAM_BRIDGE_NONCE_TTL=300

# === OUTBOX ===
TELEGRAM_OUTBOX_LEASE_SECONDS=60
TELEGRAM_OUTBOX_POLL_INTERVAL=5

# === LIMITS ===
GATEWAY_MAX_CONCURRENT_DELIVERIES=10
GATEWAY_SPOOL_MAX_SIZE_MB=1000
GATEWAY_MAX_MESSAGE_SIZE_MB=50
GATEWAY_MAX_RETRIES=5
GATEWAY_RETRY_BASE_DELAY=30

# === DOMAIN ===
TG_DOMAIN=gateway.example.com

# === LOGGING ===
LOG_LEVEL=INFO
ENVIRONMENT=production
