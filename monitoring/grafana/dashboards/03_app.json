{
  "title": "Application — PM Agent Metrics",
  "uid": "pm-app",
  "tags": ["pm-agent", "application"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "LLM Requests / sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"]}
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(pm_llm_requests_total{status=\"success\"}[5m]))",
          "legendFormat": "{{ model }} OK",
          "refId": "A"
        },
        {
          "expr": "sum by (model) (rate(pm_llm_requests_total{status=\"error\"}[5m]))",
          "legendFormat": "{{ model }} ERR",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "LLM Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 5}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean"]}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, model) (rate(pm_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ model }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(pm_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{ model }}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, model) (rate(pm_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{ model }}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM Tokens / min",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean"]}
      },
      "targets": [
        {
          "expr": "sum by (model, token_type) (rate(pm_llm_tokens_total[5m])) * 60",
          "legendFormat": "{{ model }} {{ token_type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tool Executions / sec",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean"]}
      },
      "targets": [
        {
          "expr": "sum by (tool_name, status) (rate(pm_tool_executions_total[5m]))",
          "legendFormat": "{{ tool_name }} {{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Confirms Pending",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "pm_agent_confirms_pending",
          "legendFormat": "Pending confirms",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "DB Pool — Checked Out Connections",
      "type": "timeseries",
      "gridPos": {"h": 5, "w": 18, "x": 6, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": []}
      },
      "targets": [
        {
          "expr": "pm_db_pool_checked_out",
          "legendFormat": "Checked out",
          "refId": "A"
        }
      ]
    }
  ]
}
