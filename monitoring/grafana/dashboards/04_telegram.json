{
  "title": "Telegram — Gateway + Bridge",
  "uid": "telegram-gateway",
  "tags": ["telegram", "gateway", "bridge"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Gateway: Webhook Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_gateway_webhook_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Gateway: Spool Depth",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 500}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "telegram_gateway_spool_depth",
          "legendFormat": "spool"
        }
      ]
    },
    {
      "id": 3,
      "title": "Gateway: Forward Success Rate",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 90},
              {"color": "green", "value": 98}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(telegram_gateway_forward_total{status=\"success\"}[5m])) / sum(rate(telegram_gateway_forward_total[5m]))",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Gateway: Outbound Deliveries / sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_gateway_deliver_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Bridge: Ingest Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_bridge_ingest_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Bridge: Lease Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_bridge_lease_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Bridge: ACK Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_bridge_ack_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Bridge: Business Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_business_connection_total[5m])) by (event)",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Gateway: Bot API Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(telegram_gateway_bot_api_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(telegram_gateway_bot_api_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(telegram_gateway_bot_api_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 10,
      "title": "Gateway: Bot API Response Codes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_gateway_bot_api_total[5m])) by (code)",
          "legendFormat": "HTTP {{code}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Gateway: Deliver Latency p50/p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(telegram_gateway_deliver_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(telegram_gateway_deliver_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 12,
      "title": "Gateway: Heartbeat",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(telegram_gateway_heartbeat_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []},
  "links": []
}
