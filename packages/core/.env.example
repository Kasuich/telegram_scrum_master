# =============================================================================
# PM Agent Platform - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://pm_agent:pm_agent_password@localhost:5432/pm_agent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Yandex Cloud
# Get from: https://console.cloud.yandex.ru → Service Accounts
# -----------------------------------------------------------------------------
YC_API_KEY=YandexCloud_api_key_here
YC_FOLDER_ID=b1g00000000000000000

# -----------------------------------------------------------------------------
# Yandex Tracker
# Get from: https://tracker.yandex.ru → Settings → API → OAuth token
# Organization: https://admin.yandex.ru → Organizations → ID
# -----------------------------------------------------------------------------
TRACKER_TOKEN=OAuth_token_here
TRACKER_ORG_ID=00000000000000000000
TRACKER_QUEUE=TEST
TRACKER_API_BASE=https://api.tracker.yandex.net/v3/
# Search: by default tracker_find_issues / tracker_search_issues skip closed & cancelled.
# TRACKER_SEARCH_ALL_STATUSES=true
# TRACKER_TERMINAL_STATUSES=Closed,Закрыт,Отменена
# TRACKER_DEDUP_ENABLED=true
# TRACKER_CANCELLED_STATUSES=Cancelled,Отменена

# -----------------------------------------------------------------------------
# YandexGPT (LLM)
# -----------------------------------------------------------------------------
YANDEXGPT_MODEL=gpt-oss-120b
YANDEXGPT_TEMPERATURE=0.7
YANDEXGPT_MAX_TOKENS=4000
YANDEXGPT_TOP_P=0.9
YANDEXGPT_TIMEOUT=60
YANDEXGPT_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# OpenRouter (third-party LLM: Gemini, Claude, etc.)
# Get from: https://openrouter.ai → Settings → API Keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-3.1-flash-lite

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SERVICE_NAME=pm-agent-platform
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# -----------------------------------------------------------------------------
# Runtime (optional, can be overridden per-team)
# -----------------------------------------------------------------------------
# RUNTIME_SKIP_TOOL_CONFIRM=true
# Optional nicknames if fuzzy match is weak: {"коля":"nukolaus","рома":"shinkarenkorom"}
# TRACKER_ASSIGNEE_ALIASES={}
# DEFAULT_TEAM_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Backlog planning (meeting summary → Tracker board)
# -----------------------------------------------------------------------------
# BACKLOG_VELOCITY_SP_PER_WEEK=20
# BACKLOG_START_DATE=2026-06-04
# BACKLOG_MIN_SUMMARY_CHARS=800
# BACKLOG_DEDUP_ENABLED=true
# BACKLOG_DEDUP_SIMILARITY=0.88
