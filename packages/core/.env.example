# =============================================================================
# PM Agent Platform - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://pm_agent:pm_agent_password@localhost:5432/pm_agent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Yandex Cloud
# Get from: https://console.cloud.yandex.ru → Service Accounts
# -----------------------------------------------------------------------------
YC_API_KEY=YandexCloud_api_key_here
YC_FOLDER_ID=b1g00000000000000000

# -----------------------------------------------------------------------------
# Yandex Tracker
# Get from: https://tracker.yandex.ru → Settings → API → OAuth token
# Organization: https://admin.yandex.ru → Organizations → ID
# -----------------------------------------------------------------------------
TRACKER_TOKEN=OAuth_token_here
TRACKER_ORG_ID=00000000000000000000
TRACKER_QUEUE=TEST
TRACKER_API_BASE=https://api.tracker.yandex.net/v3/

# -----------------------------------------------------------------------------
# YandexGPT (LLM)
# -----------------------------------------------------------------------------
YANDEXGPT_MODEL=yandexgpt
YANDEXGPT_TEMPERATURE=0.7
YANDEXGPT_MAX_TOKENS=4000
YANDEXGPT_TOP_P=0.9
YANDEXGPT_TIMEOUT=60
YANDEXGPT_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SERVICE_NAME=pm-agent-platform
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# -----------------------------------------------------------------------------
# Runtime (optional, can be overridden per-team)
# -----------------------------------------------------------------------------
# TEAM_ID=your_team_id_here
